# 1. Беремо офіційний, ультралегкий образ Nginx на базі Alpine Linux
FROM nginx:alpine

# 2. Копіюємо всі наші файли фронтенду в папку, з якої Nginx за замовчуванням роздає сайти
COPY . /usr/share/nginx/html

# 3. Відкриваємо стандартний веб-порт 80
EXPOSE 80

# Nginx запускається автоматично, тому команду CMD тут писати не обов'язково
