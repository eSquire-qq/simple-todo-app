# 1. Завантажуємо готовий офіційний образ Node.js
FROM node:20-alpine

# 2. Створюємо папку для програми всередині контейнера
WORKDIR /app

# 3. Копіюємо файли конфігурації залежностей
COPY package*.json ./

# 4. Встановлюємо всі бібліотеки прямо всередині контейнера
RUN npm install

# 5. Копіюємо решту файлів проекту (код сайту)
COPY . .

# 6. Вказуємо порт 4000 (той, що у твоєму .env)
EXPOSE 4000

# 7. Команда, яка запустить твій сервер всередині Docker
CMD ["npm", "start"]
